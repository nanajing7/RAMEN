estimate = coef_avg$estimate[match(true_coef_names, coef_avg$term)],
stringsAsFactors = FALSE
)
}
extract_ols_coef <- function(lm_obj, true_coef_names) {
cf <- coef(lm_obj)
name_map <- c(
"x_row_1"  = "row:x_row_1",
"x_row_2"  = "row:x_row_2",
"x_col_1"  = "col:x_col_1",
"x_col_2"  = "col:x_col_2",
"x_dyad_1" = "dyad:x_dyad_1"
)
keep <- intersect(names(cf), names(name_map))
tmp <- data.frame(
term     = unname(name_map[keep]),
estimate = unname(cf[keep]),
stringsAsFactors = FALSE
)
data.frame(
term     = true_coef_names,
estimate = tmp$estimate[match(true_coef_names, tmp$term)],
stringsAsFactors = FALSE
)
}
# fixed-size row covariate matrix builder
make_row_cov_matrix <- function(df, row_ids, covar_names) {
out <- matrix(NA_real_, nrow = length(row_ids), ncol = length(covar_names),
dimnames = list(row_ids, covar_names))
tmp <- df %>%
distinct(node_row, .keep_all = TRUE) %>%
dplyr::select(node_row, all_of(covar_names))
idx <- match(tmp$node_row, row_ids)
out[idx, ] <- as.matrix(tmp[, covar_names, drop = FALSE])
out
}
# fixed-size col covariate matrix builder
make_col_cov_matrix <- function(df, col_ids, covar_names) {
out <- matrix(NA_real_, nrow = length(col_ids), ncol = length(covar_names),
dimnames = list(col_ids, covar_names))
tmp <- df %>%
distinct(node_col, .keep_all = TRUE) %>%
dplyr::select(node_col, all_of(covar_names))
idx <- match(tmp$node_col, col_ids)
out[idx, ] <- as.matrix(tmp[, covar_names, drop = FALSE])
out
}
# fixed-size dyad matrix builder
long_to_matrix <- function(df, value_col, row_ids, col_ids) {
out <- matrix(NA_real_, nrow = length(row_ids), ncol = length(col_ids),
dimnames = list(row_ids, col_ids))
r_idx <- match(df$node_row, row_ids)
c_idx <- match(df$node_col, col_ids)
ok <- !is.na(r_idx) & !is.na(c_idx)
out[cbind(r_idx[ok], c_idx[ok])] <- df[[value_col]][ok]
out
}
compute_cross_dyad_means <- function(base_mat) {
N <- nrow(base_mat)
M <- ncol(base_mat)
row_sum <- rowSums(base_mat)
col_sum <- colSums(base_mat)
same_row_mean <- matrix(0, N, M)
same_col_mean <- matrix(0, N, M)
for (j in seq_len(M)) {
same_row_mean[, j] <- (row_sum - base_mat[, j]) / (M - 1)
}
for (i in seq_len(N)) {
same_col_mean[i, ] <- (col_sum - base_mat[i, ]) / (N - 1)
}
list(
same_row_mean = same_row_mean,
same_col_mean = same_col_mean
)
}
build_matrix_objects_from_long <- function(dyad_df, years, row_ids, col_ids) {
Y_list          <- vector("list", length(years))
structural_list <- vector("list", length(years))
X_row_list      <- vector("list", length(years))
X_col_list      <- vector("list", length(years))
X_dyad_list     <- vector("list", length(years))
row_covar_names  <- c("x_row_1", "x_row_2")
col_covar_names  <- c("x_col_1", "x_col_2")
dyad_covar_names <- c("x_dyad_1")
for (tt in seq_along(years)) {
yr <- years[tt]
yr_df <- dyad_df %>% filter(year == yr)
Y_t <- long_to_matrix(yr_df, "value", row_ids, col_ids)
S_t <- long_to_matrix(yr_df, "signal", row_ids, col_ids)
Xr <- make_row_cov_matrix(yr_df, row_ids, row_covar_names)
Xc <- make_col_cov_matrix(yr_df, col_ids, col_covar_names)
Xd_mat <- long_to_matrix(yr_df, "x_dyad_1", row_ids, col_ids)
Xd_arr <- array(
Xd_mat,
dim = c(length(row_ids), length(col_ids), 1),
dimnames = list(row_ids, col_ids, "x_dyad_1")
)
Y_list[[tt]]          <- Y_t
structural_list[[tt]] <- S_t
X_row_list[[tt]]      <- Xr
X_col_list[[tt]]      <- Xc
X_dyad_list[[tt]]     <- Xd_arr
}
list(
Y_list = Y_list,
structural_list = structural_list,
X_row_list = X_row_list,
X_col_list = X_col_list,
X_dyad_list = X_dyad_list
)
}
make_covariate_dfs_from_long <- function(dyad_df) {
row_cov_df <- dyad_df %>%
distinct(year, node_row, x_row_1, x_row_2)
col_cov_df <- dyad_df %>%
distinct(year, node_col, x_col_1, x_col_2)
dyad_cov_df <- dyad_df %>%
distinct(year, node_row, node_col, x_dyad_1)
list(
row_cov_df  = row_cov_df,
col_cov_df  = col_cov_df,
dyad_cov_df = dyad_cov_df
)
}
# ------------------------------------------------------------
# 3. Storage
# ------------------------------------------------------------
ols_store   <- vector("list", n_rep)
pkg_store   <- vector("list", n_rep)
success_ols <- logical(n_rep)
success_pkg <- logical(n_rep)
rmse_ols_store <- rep(NA_real_, n_rep)
rmse_pkg_store <- rep(NA_real_, n_rep)
fitted_cor_ols <- rep(NA_real_, n_rep)
fitted_cor_pkg <- rep(NA_real_, n_rep)
signal_cor_ols <- rep(NA_real_, n_rep)
signal_cor_pkg <- rep(NA_real_, n_rep)
# ------------------------------------------------------------
# 4. Monte Carlo loop
# ------------------------------------------------------------
for (rr in seq_len(n_rep)) {
cat(sprintf("\nReplication %d / %d\n", rr, n_rep))
# ----------------------------------------------------------
# 4.1 Generate temporal row/col effects + latent factors
# ----------------------------------------------------------
alpha_list <- vector("list", TT)
beta_list  <- vector("list", TT)
U_list     <- vector("list", TT)
V_list     <- vector("list", TT)
for (tt in seq_len(TT)) {
if (tt == 1) {
alpha_t <- rnorm(N, sd = sd_alpha0)
beta_t  <- rnorm(M, sd = sd_beta0)
U_t     <- matrix(rnorm(N * K, sd = sd_U0), N, K)
V_t     <- matrix(rnorm(M * K, sd = sd_V0), M, K)
} else {
alpha_t <- phi_alpha * alpha_list[[tt - 1]] + rnorm(N, sd = sd_alpha_innov)
beta_t  <- phi_beta  * beta_list[[tt - 1]]  + rnorm(M, sd = sd_beta_innov)
U_t     <- phi_U     * U_list[[tt - 1]]     + matrix(rnorm(N * K, sd = sd_U_innov), N, K)
V_t     <- phi_V     * V_list[[tt - 1]]     + matrix(rnorm(M * K, sd = sd_V_innov), M, K)
}
names(alpha_t) <- row_ids
names(beta_t)  <- col_ids
rownames(U_t)  <- row_ids
rownames(V_t)  <- col_ids
alpha_list[[tt]] <- alpha_t
beta_list[[tt]]  <- beta_t
U_list[[tt]]     <- U_t
V_list[[tt]]     <- V_t
}
# ----------------------------------------------------------
# 4.2 Generate long dyadic data first
# ----------------------------------------------------------
dyad_panel <- vector("list", TT)
for (tt in seq_len(TT)) {
yr <- years[tt]
base_grid <- expand.grid(
node_row = row_ids,
node_col = col_ids,
stringsAsFactors = FALSE
) %>%
mutate(year = yr)
if (tt == 1) {
row_cov_t <- data.frame(
node_row = row_ids,
x_row_1  = rnorm(N),
x_row_2  = rnorm(N),
stringsAsFactors = FALSE
)
col_cov_t <- data.frame(
node_col = col_ids,
x_col_1  = rnorm(M),
x_col_2  = rnorm(M),
stringsAsFactors = FALSE
)
dyad_cov_t <- base_grid %>%
transmute(node_row, node_col, x_dyad_1 = rnorm(n()))
} else {
prev_rows <- dyad_panel[[tt - 1]] %>%
distinct(node_row, x_row_1, x_row_2)
prev_cols <- dyad_panel[[tt - 1]] %>%
distinct(node_col, x_col_1, x_col_2)
prev_dyad <- dyad_panel[[tt - 1]] %>%
distinct(node_row, node_col, x_dyad_1)
row_cov_t <- prev_rows %>%
mutate(
x_row_1 = 0.50 * x_row_1 + rnorm(n(), sd = 0.8),
x_row_2 = 0.50 * x_row_2 + rnorm(n(), sd = 0.8)
)
col_cov_t <- prev_cols %>%
mutate(
x_col_1 = 0.50 * x_col_1 + rnorm(n(), sd = 0.8),
x_col_2 = 0.50 * x_col_2 + rnorm(n(), sd = 0.8)
)
dyad_cov_t <- prev_dyad %>%
mutate(
x_dyad_1 = 0.40 * x_dyad_1 + rnorm(n(), sd = 0.9)
)
}
dyad_df_t <- base_grid %>%
left_join(row_cov_t,  by = "node_row") %>%
left_join(col_cov_t,  by = "node_col") %>%
left_join(dyad_cov_t, by = c("node_row", "node_col"))
# add latent pieces
dyad_df_t <- dyad_df_t %>%
mutate(
alpha_t = alpha_list[[tt]][node_row],
beta_t  = beta_list[[tt]][node_col],
u1 = U_list[[tt]][node_row, 1],
u2 = U_list[[tt]][node_row, 2],
v1 = V_list[[tt]][node_col, 1],
v2 = V_list[[tt]][node_col, 2]
)
# base signal
dyad_df_t <- dyad_df_t %>%
mutate(
row_part    = coef_row_true[1] * x_row_1 + coef_row_true[2] * x_row_2,
col_part    = coef_col_true[1] * x_col_1 + coef_col_true[2] * x_col_2,
dyad_part   = coef_dyad_true[1] * x_dyad_1,
year_part   = delta_true[as.character(yr)],
latent_part = u1 * v1 + u2 * v2,
base_signal = row_part + col_part + dyad_part + year_part +
alpha_t + beta_t + latent_part
)
# compute cross-dyad dependence using matrix of base signal
base_mat <- long_to_matrix(dyad_df_t, "base_signal", row_ids, col_ids)
dep_means <- compute_cross_dyad_means(base_mat)
same_row_df <- expand.grid(
node_row = row_ids,
node_col = col_ids,
stringsAsFactors = FALSE
) %>%
mutate(
same_row_mean = as.vector(dep_means$same_row_mean),
same_col_mean = as.vector(dep_means$same_col_mean)
)
dyad_df_t <- dyad_df_t %>%
left_join(same_row_df, by = c("node_row", "node_col")) %>%
mutate(
signal = base_signal +
rho_row * same_row_mean +
rho_col * same_col_mean,
eps   = rnorm(n(), sd = sigma_eps),
value = signal + eps
)
dyad_panel[[tt]] <- dyad_df_t
}
analysis_df <- bind_rows(dyad_panel)
# ----------------------------------------------------------
# 4.3 Convert long data to matrix/list objects for package
# ----------------------------------------------------------
mat_objs <- build_matrix_objects_from_long(
dyad_df = analysis_df,
years   = years,
row_ids = row_ids,
col_ids = col_ids
)
Y_list          <- mat_objs$Y_list
structural_list <- mat_objs$structural_list
X_row_list      <- mat_objs$X_row_list
X_col_list      <- mat_objs$X_col_list
X_dyad_list     <- mat_objs$X_dyad_list
edge_panel <- analysis_df %>%
dplyr::select(year, node_row, node_col, value)
covars <- make_covariate_dfs_from_long(analysis_df)
row_cov_df  <- covars$row_cov_df
col_cov_df  <- covars$col_cov_df
dyad_cov_df <- covars$dyad_cov_df
# ----------------------------------------------------------
# 4.4 Naive dyadic OLS
# ----------------------------------------------------------
ols_try <- try(
lm(
value ~ x_row_1 + x_row_2 + x_col_1 + x_col_2 + x_dyad_1 + factor(year),
data = analysis_df
),
silent = TRUE
)
if (!inherits(ols_try, "try-error")) {
ols_coef_df <- extract_ols_coef(ols_try, true_coef_names)
ols_store[[rr]] <- data.frame(
term     = true_coef_names,
truth    = true_coef_vec,
estimate = ols_coef_df$estimate,
method   = "OLS",
rep      = rr,
stringsAsFactors = FALSE
)
success_ols[rr] <- TRUE
analysis_df$ols_fitted <- predict(ols_try, newdata = analysis_df)
rmse_ols_store[rr] <- sqrt(mean((analysis_df$ols_fitted - analysis_df$value)^2))
fitted_cor_ols[rr] <- cor(analysis_df$ols_fitted, analysis_df$value)
signal_cor_ols[rr] <- cor(analysis_df$ols_fitted, analysis_df$signal)
}
# ----------------------------------------------------------
# 4.5 Package fit
# ----------------------------------------------------------
pkg_try <- try(
fit_temporal_bipartite_als(
edge_panel               = edge_panel,
row_cov_df               = row_cov_df,
col_cov_df               = col_cov_df,
dyad_cov_df              = dyad_cov_df,
row_covar_names          = c("x_row_1", "x_row_2"),
col_covar_names          = c("x_col_1", "x_col_2"),
dyad_covar_names         = "x_dyad_1",
time_col                 = "year",
row_col                  = "node_row",
col_col                  = "node_col",
value_col                = "value",
transform                = identity,
demean_row_covariates    = TRUE,
demean_col_covariates    = TRUE,
K                        = K,
lambda                   = 0,
gamma                    = 0,
verbose                  = FALSE
),
silent = TRUE
)
if (!inherits(pkg_try, "try-error")) {
pkg_coef_df <- extract_pkg_coef(pkg_try, true_coef_names)
pkg_store[[rr]] <- data.frame(
term     = true_coef_names,
truth    = true_coef_vec,
estimate = pkg_coef_df$estimate,
method   = "Package",
rep      = rr,
stringsAsFactors = FALSE
)
success_pkg[rr] <- TRUE
last_period <- as.character(max(years))
res_last    <- pkg_try$results[[last_period]]
coef_last <- pkg_try$coef_df %>%
filter(period == as.integer(last_period))
cr <- setNames(
coef_last$coefficient[coef_last$type == "row"],
coef_last$covariate[coef_last$type == "row"]
)
cc <- setNames(
coef_last$coefficient[coef_last$type == "col"],
coef_last$covariate[coef_last$type == "col"]
)
cd <- coef_last$coefficient[coef_last$type == "dyad"]
fitted_last <-
matrix(res_last$alpha, N, M, byrow = FALSE) +
matrix(res_last$beta,  N, M, byrow = TRUE)  +
matrix(X_row_list[[TT]][, names(cr), drop = FALSE] %*% cr, N, M, byrow = FALSE) +
matrix(X_col_list[[TT]][, names(cc), drop = FALSE] %*% cc, N, M, byrow = TRUE)  +
cd * X_dyad_list[[TT]][, , 1] +
res_last$U %*% t(res_last$V)
rmse_pkg_store[rr] <- sqrt(mean((fitted_last - Y_list[[TT]])^2))
fitted_cor_pkg[rr] <- cor(as.vector(fitted_last), as.vector(Y_list[[TT]]))
signal_cor_pkg[rr] <- cor(as.vector(fitted_last), as.vector(structural_list[[TT]]))
}
}
# ------------------------------------------------------------
# 5. Summaries
# ------------------------------------------------------------
ols_results <- safe_rbind(ols_store[success_ols])
pkg_results <- safe_rbind(pkg_store[success_pkg])
if (is.null(ols_results) && is.null(pkg_results)) {
stop("No successful fits.")
}
all_results <- bind_rows(ols_results, pkg_results)
summary_table <- all_results %>%
group_by(term, method) %>%
summarise(
truth    = mean(truth, na.rm = TRUE),
mean_est = mean(estimate, na.rm = TRUE),
bias     = mean(estimate - truth, na.rm = TRUE),
rmse     = sqrt(mean((estimate - truth)^2, na.rm = TRUE)),
ci_lo    = quantile(estimate, 0.025, na.rm = TRUE),
ci_hi    = quantile(estimate, 0.975, na.rm = TRUE),
.groups  = "drop"
) %>%
arrange(term, method)
cat("\n==============================\n")
cat("Coefficient Recovery Summary\n")
cat("==============================\n\n")
print(summary_table, digits = 3)
fit_summary <- data.frame(
method = c("OLS", "Package"),
mean_rmse = c(
mean(rmse_ols_store[success_ols], na.rm = TRUE),
mean(rmse_pkg_store[success_pkg], na.rm = TRUE)
),
sd_rmse = c(
sd(rmse_ols_store[success_ols], na.rm = TRUE),
sd(rmse_pkg_store[success_pkg], na.rm = TRUE)
),
mean_fit_cor = c(
mean(fitted_cor_ols[success_ols], na.rm = TRUE),
mean(fitted_cor_pkg[success_pkg], na.rm = TRUE)
),
sd_fit_cor = c(
sd(fitted_cor_ols[success_ols], na.rm = TRUE),
sd(fitted_cor_pkg[success_pkg], na.rm = TRUE)
),
mean_signal_cor = c(
mean(signal_cor_ols[success_ols], na.rm = TRUE),
mean(signal_cor_pkg[success_pkg], na.rm = TRUE)
),
sd_signal_cor = c(
sd(signal_cor_ols[success_ols], na.rm = TRUE),
sd(signal_cor_pkg[success_pkg], na.rm = TRUE)
)
)
cat("\n==============================\n")
cat("Model Fit Summary\n")
cat("==============================\n\n")
print(fit_summary, digits = 3)
cat(sprintf(
"\nOLS succeeded in %d / %d replications\n",
sum(success_ols), n_rep
))
cat(sprintf(
"Package succeeded in %d / %d replications\n",
sum(success_pkg), n_rep
))
# ------------------------------------------------------------
# 6. Visualization
# ------------------------------------------------------------
plot_df <- summary_table %>%
mutate(term = factor(term, levels = true_coef_names))
truth_df <- data.frame(
term  = factor(true_coef_names, levels = true_coef_names),
truth = true_coef_vec
)
p <- ggplot(plot_df, aes(x = mean_est, y = term, shape = method)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "grey60") +
geom_errorbarh(
aes(xmin = ci_lo, xmax = ci_hi),
height = 0.15,
position = position_dodge(width = 0.50)
) +
geom_point(
position = position_dodge(width = 0.50),
size = 3
) +
geom_point(
data = truth_df,
aes(x = truth, y = term),
inherit.aes = FALSE,
shape = 17,
color = "red",
size = 3
) +
theme_minimal(base_size = 13) +
labs(
title = "Coefficient recovery: naive OLS vs temporal bipartite ALS",
subtitle = "Long-dyad-first DGP with cross-dyad dependence",
x = "Coefficient value",
y = NULL
)
print(p)
# ------------------------------------------------------------
# 7. Wide comparison table
# ------------------------------------------------------------
comparison_table <- summary_table %>%
dplyr::select(term, method, truth, mean_est, bias, rmse, ci_lo, ci_hi) %>%
pivot_wider(
names_from = method,
values_from = c(mean_est, bias, rmse, ci_lo, ci_hi)
) %>%
arrange(term)
cat("\n==============================\n")
cat("Wide Comparison Table\n")
cat("==============================\n\n")
print(comparison_table, digits = 3)
# ----------------------------------------------------------
# 4.4 Naive dyadic OLS
# ----------------------------------------------------------
ols_try <- try(
lm(
value ~ x_row_1 + x_row_2 + x_col_1 + x_col_2 + x_dyad_1 + factor(year),
data = analysis_df
),
silent = TRUE
)
ols_try
# ----------------------------------------------------------
# 4.4 Naive dyadic OLS
# ----------------------------------------------------------
ols_try <- try(
m <- lm(
value ~ x_row_1 + x_row_2 + x_col_1 + x_col_2 + x_dyad_1 + factor(year),
data = analysis_df
),
silent = TRUE
)
summary(m)
